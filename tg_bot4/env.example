# PostgreSQL connection
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/jobbot

# Flask secret key — change to any long random string
SECRET_KEY=change-me-to-something-random-32chars

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Gmail credentials are now set per-user inside the web app (signup / settings).
# You no longer need to set them here.

# Fernet encryption key for Gmail App Passwords stored in DB.
# Generate once with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_generated_fernet_key_here
