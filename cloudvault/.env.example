# ── CloudVault Environment Config ──────────────────────

# PostgreSQL connection string (leave empty to use local JSON db)
# Format: postgresql://user:password@host:5432/dbname
# Examples:
#   Supabase:  postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
#   Neon:      postgresql://[USER]:[PASSWORD]@[HOST]/[DB]?sslmode=require
#   Railway:   postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/railway
#   Local:     postgresql://localhost/cloudvault
DATABASE_URL=

# Optional: override JWT secret (auto-generated and saved to data/.secret if empty)
JWT_SECRET=

# Port (default: 3000)
PORT=3000
